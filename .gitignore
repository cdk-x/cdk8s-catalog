# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
dist-jsii
tmp
out-tsc
site

# jsii build artifacts (regenerated by the jsii-compile target)
.jsii
tsconfig.tsbuildinfo

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

# never commit exported key material (e.g. GPG keys for Maven Central signing)
*.pem

.nx/cache
.nx/workspace-data
.nx/migrate-runs
.claude/worktrees
.claude/settings.local.json

.nx/polygraph
test-output

# e2e projects install from the local Verdaccio registry, not the pnpm workspace
e2e/**/package-lock.json
e2e/**/manifests

# generated by tools/docs-prepare-library.mjs
packages/*/docs/_compat.md
packages/*/docs/_lang-switcher.md
packages/*/docs/stylesheets/extra.css
packages/*/docs/api

# generated by tools/docs-preview.mjs - a local, disposable stand-in for
# gh-pages, never a git branch
.docs-preview
